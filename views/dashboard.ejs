<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link href="/styles.css" rel="stylesheet">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/dashboard">
                <i class="fab fa-facebook me-2"></i>
                Facebook Auto Tool
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="/dashboard">
                            <i class="fas fa-tachometer-alt me-1"></i>
                            Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#" id="refreshDashboard">
                            <i class="fas fa-sync-alt me-1"></i>
                            Refresh
                        </a>
                    </li>
                </ul>
                
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user-circle me-1"></i>
                            <%= user.username %>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/login.html">
                                <i class="fas fa-plus me-2"></i>
                                Add Facebook Account
                            </a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="#" id="logoutBtn">
                                <i class="fas fa-sign-out-alt me-2"></i>
                                Logout
                            </a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container-fluid py-4">
        <!-- Alert Container -->
        <div id="alertContainer"></div>
        
        <!-- Dashboard Stats -->
        <div class="row g-4 mb-4">
            <div class="col-lg-3 col-md-6">
                <div class="stat-card success" id="activeSessions">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-success text-white">
                            <i class="fas fa-users"></i>
                        </div>
                        <div class="ms-3">
                            <div class="stat-value fs-3 fw-bold"><%= sessions.totalActive %></div>
                            <div class="stat-label text-muted">Active Sessions</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-md-6">
                <div class="stat-card info" id="todayActions">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-info text-white">
                            <i class="fas fa-bolt"></i>
                        </div>
                        <div class="ms-3">
                            <div class="stat-value fs-3 fw-bold"><%= actions.today %></div>
                            <div class="stat-label text-muted">Today's Actions</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-md-6">
                <div class="stat-card warning" id="successRate">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-warning text-dark">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <div class="ms-3">
                            <div class="stat-value fs-3 fw-bold"><%= actions.successRate %>%</div>
                            <div class="stat-label text-muted">Success Rate</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-md-6">
                <div class="stat-card" id="totalActions">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-primary text-white">
                            <i class="fas fa-history"></i>
                        </div>
                        <div class="ms-3">
                            <div class="stat-value fs-3 fw-bold"><%= actions.total %></div>
                            <div class="stat-label text-muted">Total Actions</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Action Execution Panel -->
            <div class="col-lg-8">
                <div class="action-form">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <h4 class="mb-0">
                            <i class="fas fa-play-circle text-primary me-2"></i>
                            Execute Action
                        </h4>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-secondary btn-sm" id="clearForm">
                                <i class="fas fa-broom me-1"></i>
                                Clear
                            </button>
                        </div>
                    </div>
                    
                    <form id="actionForm">
                        <!-- Target Input -->
                        <div class="mb-4">
                            <label for="targetId" class="form-label fw-bold">Target URL or ID</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="fab fa-facebook-f"></i>
                                </span>
                                <input type="text" class="form-control" id="targetId" 
                                       placeholder="https://facebook.com/post/123... or user ID" required>
                            </div>
                            <div id="targetFeedback" class="form-text">
                                Enter a Facebook post URL, user profile URL, or user ID
                            </div>
                        </div>
                        
                        <!-- Action Selection -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Select Action</label>
                            <div id="actionGrid" class="action-grid">
                                <!-- Action buttons will be populated by JavaScript -->
                            </div>
                        </div>
                        
                        <!-- Comment Field (shown only for comment actions) -->
                        <div id="commentField" class="mb-4 d-none">
                            <label for="comment" class="form-label fw-bold">Comment Text</label>
                            <textarea class="form-control" id="comment" rows="3" 
                                      placeholder="Enter your comment here..." maxlength="2000"></textarea>
                            <div class="form-text">Maximum 2000 characters</div>
                        </div>
                        
                        <!-- Submit Button -->
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-rocket me-2"></i>
                                Execute Action
                            </button>
                        </div>
                    </form>
                </div>
                
                <!-- Recent Activity -->
                <div class="mt-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h5 class="mb-0">
                            <i class="fas fa-history text-info me-2"></i>
                            Recent Activity
                        </h5>
                        <button class="btn btn-outline-info btn-sm" id="refreshActivity">
                            <i class="fas fa-sync-alt me-1"></i>
                            Refresh
                        </button>
                    </div>
                    
                    <div class="activity-feed">
                        <% if (actions.recent && actions.recent.length > 0) { %>
                            <% actions.recent.forEach(action => { %>
                                <div class="activity-item">
                                    <div class="activity-icon <%= action.status %>">
                                        <i class="fas fa-<%= action.status === 'success' ? 'check' : 'times' %>"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-bold"><%= action.actionType %> action</div>
                                        <small class="text-muted">
                                            <%= action.targetType %> <%= action.targetId %> • 
                                            <span data-time="<%= action.executedAt %>">
                                                <%= new Date(action.executedAt).toLocaleString() %>
                                            </span>
                                        </small>
                                    </div>
                                    <span class="badge bg-<%= action.status === 'success' ? 'success' : 'danger' %>">
                                        <%= action.status %>
                                    </span>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center text-muted py-4">
                                <i class="fas fa-history fa-2x mb-3 opacity-25"></i>
                                <p>No recent activity</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
            
            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Facebook Sessions -->
                <div class="sessions-list mb-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h5 class="mb-0">
                            <i class="fab fa-facebook text-primary me-2"></i>
                            Facebook Accounts
                        </h5>
                        <button class="btn btn-outline-primary btn-sm" id="refreshSessions">
                            <i class="fas fa-sync-alt me-1"></i>
                        </button>
                    </div>
                    
                    <div class="sessions-container">
                        <% if (sessions.active && sessions.active.length > 0) { %>
                            <% sessions.active.forEach(session => { %>
                                <div class="session-item">
                                    <div class="d-flex align-items-center">
                                        <div class="session-status <%= session.isActive ? 'active' : 'inactive' %>"></div>
                                        <div>
                                            <div class="fw-bold"><%= session.maskedFbId %></div>
                                            <small class="text-muted">
                                                Added <%= new Date(session.createdAt).toLocaleDateString() %>
                                            </small>
                                        </div>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-outline-danger" 
                                                data-action="remove" data-session="<%= session.id %>">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center text-muted py-4">
                                <i class="fab fa-facebook fa-3x mb-3 opacity-25"></i>
                                <p>No Facebook accounts connected</p>
                                <a href="/login.html" class="btn btn-primary">
                                    <i class="fas fa-plus me-2"></i>
                                    Add Facebook Account
                                </a>
                            </div>
                        <% } %>
                    </div>
                    
                    <div class="mt-3 p-3 bg-light rounded">
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Active Sessions:</span>
                            <span class="fw-bold"><%= sessions.totalActive %></span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Max Allowed:</span>
                            <span class="fw-bold"><%= sessions.maxAllowed %></span>
                        </div>
                    </div>
                </div>
                
                <!-- Quick Stats -->
                <div class="bg-white rounded p-4 border">
                    <h6 class="fw-bold mb-3">
                        <i class="fas fa-chart-pie text-success me-2"></i>
                        Quick Stats
                    </h6>
                    
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Success Rate</span>
                            <span class="fw-bold text-success"><%= actions.successRate %>%</span>
                        </div>
                        <div class="progress" style="height: 6px;">
                            <div class="progress-bar bg-success" style="width: <%= actions.successRate %>%"></div>
                        </div>
                    </div>
                    
                    <div class="row g-3 text-center">
                        <div class="col-6">
                            <div class="border rounded p-3">
                                <div class="fs-4 fw-bold text-primary"><%= actions.successful %></div>
                                <small class="text-muted">Successful</small>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-3">
                                <div class="fs-4 fw-bold text-danger"><%= actions.failed %></div>
                                <small class="text-muted">Failed</small>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-3">
                                <div class="fs-4 fw-bold text-info"><%= actions.thisWeek %></div>
                                <small class="text-muted">This Week</small>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-3">
                                <div class="fs-4 fw-bold text-warning"><%= actions.today %></div>
                                <small class="text-muted">Today</small>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- System Status -->
                <div class="bg-white rounded p-4 border mt-4">
                    <h6 class="fw-bold mb-3">
                        <i class="fas fa-server text-info me-2"></i>
                        System Status
                    </h6>
                    
                    <div class="mb-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted">
                                <i class="fab fa-facebook me-1"></i>
                                Facebook Service
                            </span>
                            <span class="badge bg-<%= system.facebook.operational ? 'success' : 'danger' %>">
                                <%= system.facebook.operational ? 'Online' : 'Offline' %>
                            </span>
                        </div>
                    </div>
                    
                    <div class="mb-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted">
                                <i class="fas fa-database me-1"></i>
                                Database
                            </span>
                            <span class="badge bg-<%= system.database.connected ? 'success' : 'danger' %>">
                                <%= system.database.connected ? 'Connected' : 'Disconnected' %>
                            </span>
                        </div>
                    </div>
                    
                    <div class="mt-3 pt-3 border-top">
                        <small class="text-muted">
                            <i class="fas fa-clock me-1"></i>
                            Uptime: <%= Math.floor(system.server.uptime / 3600) %>h <%= Math.floor((system.server.uptime % 3600) / 60) %>m
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Loading Overlay -->
    <div id="loadingOverlay" class="loading-overlay d-none">
        <div class="loading-content">
            <div class="spinner-border text-primary mb-3" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <h5>Processing Action...</h5>
            <p class="text-muted mb-0">Please wait while we execute your Facebook action</p>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom JavaScript -->
    <script src="/script.js"></script>
    
    <!-- Dashboard-specific JavaScript -->
    <script>
        // Logout functionality
        document.getElementById('logoutBtn')?.addEventListener('click', async (e) => {
            e.preventDefault();
            try {
                const response = await fetch('/api/auth/logout', {
                    method: 'POST',
                    credentials: 'same-origin'
                });
                
                if (response.ok) {
                    window.location.href = '/';
                } else {
                    window.facebookApp.showAlert('Logout failed', 'danger');
                }
            } catch (error) {
                window.facebookApp.showAlert('Logout failed', 'danger');
            }
        });
        
        // Clear form functionality
        document.getElementById('clearForm')?.addEventListener('click', () => {
            document.getElementById('actionForm').reset();
            document.querySelectorAll('.action-button').forEach(btn => {
                btn.classList.remove('selected');
            });
            document.getElementById('commentField').classList.add('d-none');
            window.facebookApp.selectedAction = null;
        });
        
        // Format timestamps
        document.querySelectorAll('[data-time]').forEach(element => {
            const timestamp = element.getAttribute('data-time');
            if (timestamp && window.facebookApp) {
                element.textContent = window.facebookApp.formatDate(timestamp);
            }
        });
    </script>
</body>
</html>